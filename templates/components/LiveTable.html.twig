<div {{ attributes.defaults({class:"live-table"}) }}>
    {% set parent = this %}
    <twig:IBoxTable
        :title="title"
        :pagination="this.paginator()"
        :perPage="perPage"
        :tools="tools"
    >
        {% block tools %}
            {{ parent() }}
            <div class="col-sm-4">
                <select data-model="type" class="form-control form-control-sm">
                    {% for t in parent.getComplaintTypes() %}
                        <option value="{{ t }}" {% if t == type %}selected{% endif %}>{{ t }}</option>
                    {% endfor %}
                </select>
            </div>
        {% endblock %}

        {% block content %}
            <table class="table table-striped table-hover">
                <thead>
                <tr>
                    <th>{{ parent.order('id', 'ID')|raw }}</th>
                    <th>Image</th>
                    <th>{{ parent.order('title', 'Subject')|raw }}</th>
                    <th>{{ parent.order('type', 'Type')|raw }}</th>
                    <th>{{ parent.order('date', 'Date')|raw }}</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for complaint in parent.getRows() %}
                    <tr>
                        <td>{{ complaint.id }}</td>
                        <td>
                            <img src="{{ complaint.imageUrl }}" alt="img" class="app-avatar-img">
                        </td>
                        <td><strong>{{ complaint.title }}</strong></td>
                        <td>
                            <span class="badge badge-info">{{ complaint.type.value }}</span>
                        </td>
                        <td>{{ complaint.date|date('d.m.Y H:i') }}</td>
                        <td><small>{{ complaint.description }}</small></td>
                        <td>
                            <a href="{{ path('app_complaint_edit', {id: complaint.id}) }}" class="btn btn-xs btn-primary">
                                <twig:ux:icon name="edit"/>
                                Edit
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center">No complaints found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endblock %}
    </twig:IBoxTable>
</div>
