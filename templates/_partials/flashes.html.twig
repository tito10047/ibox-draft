{% if flashesHandled is not defined %}
    {% set flashes = app.session.flashbag.all() %}
    {% if flashes|length > 0 %}
    {% if row is not defined or row %}
        <div class="row  border-bottom white-bg dashboard-header">
            {% endif %}
            <div class="col-lg-12">
                {% for type, flashMessages in flashes %}
                    {% for flashMessage in flashMessages %}
                        <div class="alert alert-{{ type }} alert-dismissable" {{ stimulus_controller('disappear') }}>
                            <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                            {{ flashMessage|raw }}
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
            {% if row is not defined or row %}
        </div>
    {% endif %}
        <script>
            setTimeout(function () {
                var elms = document.getElementsByClassName('alert-success')
                for (var i = 0; i < elms.length; i++) {
                    elms[i].remove();
                }
            }, 4000);
        </script>
    {% endif %}
{% endif %}
