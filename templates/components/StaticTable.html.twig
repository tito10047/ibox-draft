<div{{ attributes }}>
    {% set self=this %}
    <twig:IBoxTable
        :title="title"
        :hideFooter="true"
        :tools="null"
    >
        {% block content %}
            <div class="row g-0">
                {% for item in self.getItems() %}
                    <div class="col-12 mb-2">
                        <div class="card border-0">
                            <div class="row g-0 align-items-start">
                                <div class="col-auto p-2">
                                    <img src="{{ item.imageUrl }}" class="app-avatar-img app-avatar-img--lg" alt="img">
                                </div>
                                <div class="col">
                                    <div class="card-body p-2">
                                        <div class="d-flex justify-content-between align-items-start gap-1">
                                            <h5 class="card-title mb-1 fs-6 fw-semibold">{{ item.title }}</h5>
                                            <span class="badge badge-info flex-shrink-0">{{ item.type.value }}</span>
                                        </div>
                                        <p class="card-text mb-1"><small class="text-muted">{{ item.date|date('d.m.Y H:i') }}</small></p>
                                        <p class="card-text small text-muted">{{ item.description }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <p class="text-center p-4">No recent complaints.</p>
                    </div>
                {% endfor %}
            </div>
        {% endblock %}
    </twig:IBoxTable>
</div>
